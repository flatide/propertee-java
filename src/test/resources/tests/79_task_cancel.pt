// Test 79: CANCEL_TASK kills detached process group

taskId = START_TASK("sleep 5; echo never")
cancelled = CANCEL_TASK(taskId)

if cancelled == true then
    PRINT("PASS cancel")
else
    PRINT("FAIL cancel")
end

waitResult = WAIT_TASK(taskId, 3000)
if waitResult.ok == false then
    PRINT("PASS wait killed:", waitResult.value)
else
    PRINT("FAIL wait killed")
end

status = TASK_STATUS(taskId)
if status.status == "killed" and status.alive == false then
    PRINT("PASS killed status")
else
    PRINT("FAIL killed status:", status.status, status.alive)
end
