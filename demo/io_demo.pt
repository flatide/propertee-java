// ProperTee I/O Demo — Shell Server Integration
// Requires: ShellServer running on localhost:8099

// ===== 1. Simple shell command =====
PRINT("--- Simple Shell Command ---")
result = SHELL("echo 'Hello from shell'")
if result.ok == true then
    PRINT("Output:", result.value)
else
    PRINT("Error:", result.value)
end

// ===== 2. Parallel shell execution =====
PRINT("")
PRINT("--- Parallel Shell Execution ---")

function getDate() do
    r = SHELL("date")
    if r.ok == true then return r.value end
    return "error: " + r.value
end

function getUser() do
    r = SHELL("whoami")
    if r.ok == true then return r.value end
    return "error: " + r.value
end

function getFiles() do
    r = SHELL("ls sample/ | head -5")
    if r.ok == true then return r.value end
    return "error: " + r.value
end

multi results do
    thread date: getDate()
    thread user: getUser()
    thread files: getFiles()
monitor 200
    PRINT("  [monitor] date:", results.date.status, "| user:", results.user.status, "| files:", results.files.status)
end

PRINT("Date:", results.date.value)
PRINT("User:", results.user.value)
PRINT("Files:")
PRINT(results.files.value)

// ===== 3. Piped commands =====
PRINT("")
PRINT("--- Piped Commands ---")
result = SHELL("ps aux | wc -l")
if result.ok == true then
    PRINT("Running processes:", result.value)
end

result = SHELL("echo 'cherry banana apple' | tr ' ' '\n' | sort")
if result.ok == true then
    PRINT("Sorted:", result.value)
end

// ===== 4. File I/O =====
PRINT("")
PRINT("--- File I/O ---")
result = SHELL("echo 'ProperTee was here' > /tmp/pt_demo.txt")
result = SHELL("cat /tmp/pt_demo.txt")
if result.ok == true then
    PRINT("Read from file:", result.value)
end
SHELL("rm /tmp/pt_demo.txt")
PRINT("Temp file cleaned up")

// ===== 5. Error handling =====
PRINT("")
PRINT("--- Error Handling ---")
result = SHELL("ls /nonexistent_path_xyz_12345")
if result.ok == false then
    PRINT("Expected error caught: ok=false")
else
    PRINT("Unexpected success:", result.value)
end

// ===== 6. HTTP GET =====
PRINT("")
PRINT("--- HTTP GET ---")
result = HTTP_GET("http://localhost:8099/ping")
if result.ok == true then
    PRINT("Ping response:", result.value)
end

PRINT("")
PRINT("--- Demo Complete ---")
