// Test 78: SHELL with timeout and options support

// 1. SHELL_CTX with timeout (3rd arg)
ctx = SHELL_CTX("/", {}, 5000)
if ctx.ok == true then
    r = SHELL(ctx, "echo ctx_timeout")
    if r.ok == true then
        PRINT("PASS ctx timeout:", r.value)
    else
        PRINT("FAIL ctx timeout")
    end
else
    PRINT("FAIL ctx timeout setup")
end

// 2. SHELL with options map (command, {timeout: ms})
r = SHELL("echo options_timeout", {"timeout": 5000})
if r.ok == true then
    PRINT("PASS options:", r.value)
else
    PRINT("FAIL options")
end

// 3. SHELL in multi/thread (replaces START_TASK + WAIT_TASK pattern)
function worker(name) do
    return SHELL("echo " + name)
end

multi result do
    thread alpha: worker("alpha")
    thread beta: worker("beta")
end

if result.alpha.ok == true and result.beta.ok == true then
    PRINT("PASS multi:", result.alpha.value.value, result.beta.value.value)
else
    PRINT("FAIL multi")
end
