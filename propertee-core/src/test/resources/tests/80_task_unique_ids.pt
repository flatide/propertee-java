// Test 80: SHELL in multi/thread produces distinct results

function run(name) do
    return SHELL("echo " + name)
end

multi result do
    thread a: run("first")
    thread b: run("second")
end

aOk = result.a.ok == true
bOk = result.b.ok == true

if aOk and bOk then
    aVal = result.a.value.value
    bVal = result.b.value.value
    if aVal == "first" and bVal == "second" then
        PRINT("PASS distinct outputs")
    else
        PRINT("FAIL distinct outputs:", aVal, bVal)
    end
else
    PRINT("FAIL multi shell")
end
